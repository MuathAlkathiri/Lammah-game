# Database Configuration
MONGODB_URI=mongodb://localhost:27017/lammah-quiz

# Server Configuration
PORT=3000
APP_BASE_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# Optional first admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_FULL_NAME=Admin

# AI Provider
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b
LMSTUDIO_API_KEY=dummy
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b
LM_STUDIO_API_KEY=dummy
AI_REQUEST_TIMEOUT_MS=120000
AI_MAX_TOKENS=4096
AI_ENABLE_REWRITE=false
AI_AUDIO_VOICE=Majed

# Local music uploads
UPLOADS_DIR=uploads
MUSIC_QUESTION_CATEGORY_SLUG=songs
MUSIC_DELETE_ORIGINAL_AFTER_SNIPPET=false

# Environment
NODE_ENV=development
# Incremental multi-agent reviewed-content pipeline. Defaults to false.
MULTI_AGENT_CONTENT_PIPELINE=false

# YouTube downloads are development-only by default. Explicitly enable only where permitted.
ALLOW_YOUTUBE_ASSET_DOWNLOADS=false
JIKAN_PROVIDER_ENABLED=true
JIKAN_API_BASE_URL=https://api.jikan.moe/v4
JIKAN_REQUEST_TIMEOUT_MS=10000
JIKAN_CACHE_TTL_MS=86400000
JIKAN_NEGATIVE_CACHE_TTL_MS=600000
JIKAN_MIN_REQUEST_INTERVAL_MS=400

# Optional locally: leave empty to auto-detect node_modules/.bin/wigolo or PATH.
# Docker Compose sets this explicitly to /app/node_modules/.bin/wigolo.
WIGOLO_EXECUTABLE_PATH=
WIGOLO_CACHE_FILE=.cache/entity-verification.json
