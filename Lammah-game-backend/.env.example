# Database Configuration
MONGODB_URI=mongodb://localhost:27017/lammah-quiz

# Server Configuration
PORT=3000
APP_BASE_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# Optional first admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_FULL_NAME=Admin

# AI Provider
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b
LMSTUDIO_API_KEY=dummy
AI_REQUEST_TIMEOUT_MS=120000
AI_MAX_TOKENS=4096
AI_ENABLE_REWRITE=false
AI_AUDIO_VOICE=Majed

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=SA
# Optional JSON array. If omitted, backend uses a small default Arabic/Gulf seed list.
SPOTIFY_SEED_TRACKS=[{"title":"الأماكن","artist":"محمد عبده"},{"title":"سكة سفر","artist":"راشد الماجد"}]

# Environment
NODE_ENV=development
